generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  OPERATOR
  VIEWER
}

model User {
  id           BigInt   @id @default(autoincrement())
  name         String
  username     String   @unique
  passwordHash String
  role         UserRole @default(OPERATOR)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model StatementFile {
  id             BigInt    @id @default(autoincrement())
  serverName     String
  periodYear     String
  periodMonth    String

  s3Bucket       String
  s3Key          String    @unique
  s3Etag         String?
  s3LastModified DateTime?
  fileSize       BigInt?

  localPath      String?
  syncStatus     String    @default("synced")

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model SyncJob {
  id              BigInt    @id @default(autoincrement())
  periodYear      String
  periodMonth     String
  serverName      String?
  mode            String
  status          String

  totalFound      Int       @default(0)
  totalDownloaded Int       @default(0)
  totalSkipped    Int       @default(0)
  totalFailed     Int       @default(0)

  startedAt       DateTime?
  finishedAt      DateTime?
  errorMessage    String?
  createdBy       String?
  createdAt       DateTime  @default(now())
}

model ExportJob {
  id              BigInt             @id @default(autoincrement())
  title           String
  periodYear      String
  periodMonth     String
  serverFilter    String?

  status          String
  totalAccounts   Int                @default(0)
  foundAccounts   Int                @default(0)
  missingAccounts Int                @default(0)

  outputZipPath   String?
  errorMessage    String?
  createdBy       String?
  createdAt       DateTime           @default(now())
  finishedAt      DateTime?

  accounts        ExportJobAccount[]
}

model ExportJobAccount {
  id          BigInt    @id @default(autoincrement())
  exportJobId BigInt
  account     String
  status      String
  filePath    String?
  message     String?

  exportJob   ExportJob @relation(fields: [exportJobId], references: [id], onDelete: Cascade)
}